{
  "name": "footprint-monorepo",
  "version": "1.0.0",
  "description": "Footprint: A Gamified Micro-Action Carbon Tracker for Eco-conscious consumers to understand, track, and reduce daily carbon emissions.",
  "keywords": ["sustainability", "greentech", "carbon-tracker", "eco-friendly", "ghg", "gamification"],
  "author": "Promptware Hackathon Team",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @footprint/api\" \"npm run dev -w @footprint/web\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
