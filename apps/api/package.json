{
  "name": "@footprint/api",
  "version": "1.0.0",
  "description": "Footprint Backend API for Ingesting Carbon Telemetry and Gamification",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npx tsc-watch --onSuccess \"node dist/server.js\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@footprint/carbon-math": "*",
    "@footprint/shared-types": "*",
    "@google-cloud/pubsub": "^4.4.1",
    "@google-cloud/secret-manager": "^5.6.0",
    "@prisma/client": "^5.15.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "prisma": "^5.15.0",
    "supertest": "^7.2.2",
    "tsc-watch": "^6.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "prisma": {
